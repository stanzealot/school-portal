# API (no trailing slash)
VITE_API_BASE_URL=https://ksu.onrender.com/ksu

# Demo login (student / lecturer / exam_officer, password demo) only applies when this is enabled.
# For local dev: copy this file to `.env.local` and set VITE_DEMO_MODE=true, then restart `npm run dev`.
# Without it, the real API is used and demo usernames will fail (e.g. 400 Bad Request).
# Never use in production for real users.
# VITE_DEMO_MODE=true

# Optional: only if POST /auth/login requires a gateway Bearer token
# VITE_LOGIN_AUTHORIZATION_BEARER=
